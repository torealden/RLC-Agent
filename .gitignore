# SEC EDGAR — track the small/valuable artifacts, ignore the bulky raw filings.
# Keep:  extraction.json (LLM output, ~5KB each), index.json (filing index,
#        ~3KB each), manifest.csv, extractions_manifest.csv, the ticker xlsx.
# Skip:  the actual .htm/.xml/.zip/.xsd/image files filed with the SEC
#        (~50-300KB each, reproducible via scripts/sec_edgar_puller.py).
# Two patterns: legacy top-level layout AND new nested
# <TICKER>/public_reports/sec_filings/<accession>/ layout (per
# domain_knowledge/company_reports/README.md).
domain_knowledge/company_reports/*/[0-9]*_*/*.htm
domain_knowledge/company_reports/*/[0-9]*_*/*.html
domain_knowledge/company_reports/*/[0-9]*_*/*.xml
domain_knowledge/company_reports/*/[0-9]*_*/*.xsd
domain_knowledge/company_reports/*/[0-9]*_*/*.zip
domain_knowledge/company_reports/*/[0-9]*_*/*.jpg
domain_knowledge/company_reports/*/[0-9]*_*/*.jpeg
domain_knowledge/company_reports/*/[0-9]*_*/*.png
domain_knowledge/company_reports/*/[0-9]*_*/*.gif
domain_knowledge/company_reports/*/[0-9]*_*/*.css
domain_knowledge/company_reports/*/[0-9]*_*/*.js
domain_knowledge/company_reports/*/[0-9]*_*/*.txt
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.htm
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.html
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.xml
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.xsd
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.zip
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.jpg
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.jpeg
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.png
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.gif
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.css
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.js
domain_knowledge/company_reports/*/public_reports/sec_filings/[0-9]*_*/*.txt
domain_knowledge/company_reports/company_tickers_cache.json

# Temp files (.tmp.<pid>.<timestamp>) created by editors and tooling
*.tmp.*

# Per-collector state / cache files in data/
data/cache/
data/backfill_*.json
data/backfill_progress.json
data/last_run_*.json

# Raw GIS / crop progress downloads — re-fetchable, very large
data/crop_progress_conditions/

# EIA biofuels live + Wayback-archived downloads — re-fetchable
data/eia_biofuels/

# Full DB exports — never commit (74MB+, contains state)
database/exports/

# Large GIS reference files (re-downloadable from NTAD)
*.kmz

# Collector working outputs — large xlsx/json snapshots, regenerated by the
# collectors themselves; not source-of-truth.
collectors/epa_echo/output/
collectors/epa_echo/raw/

# Per-state local permit scraping artifacts (downloaded PDFs, captured HTML)
# Keep the scrapers themselves (scripts/permit_scrapers/) but skip the data.
data/raw/state_air_permits/

# BioTrack scraper outputs
biotrack/data/

# Conference / pitch deck working files — too many revisions, large pptx
conferences/*.pptx
conferences/*.pdf
conferences/*.gif
conferences/*.png
conferences/build_v*.py

# Internal client materials — large binaries, sometimes confidential
clients/*.pptx
clients/*.pdf
clients/*.docx
clients/Logo/
clients/alan/

# Dashboard local data + Power BI binaries
dashboards/data/
dashboards/powerbi/*.pbix
dashboards/powerbi/*.pbit

# Local Claude/editor settings
.claude/settings.local.json
.claude/settings.local.json.tmp.*

# MCP config — contains API tokens, must not be committed
.mcp.json

# State air-permit scraper artifacts.
# Keep the small JSON outputs (metadata.json, documents_index.json) per
# facility — they're the load-bearing extraction. Skip bulk CSV
# downloads, zip files, Playwright storage state, raw HTML / PDF
# captures.
data/raw/state_air_permits/*/*.zip
data/raw/state_air_permits/*/*.csv
data/raw/state_air_permits/*/*.html
data/raw/state_air_permits/*/.session.json
data/raw/state_air_permits/*/metadata/
# Per-facility intermediate files we don't need in git
data/raw/state_air_permits/*/*_documents.json
data/raw/state_air_permits/*/*_sites_*.json
data/raw/state_air_permits/*/*_wimn_page.html


# Working models — large xlsm/xlsx workbooks that bloat the repo with every save.
# Local-only; restore from .bak.{date} backups the updater scripts create.
Models/
models/
data/permits/

# Organized permit archive: keep the curated text artifacts (equipment_list.csv,
# extraction_summary.md, process_flow_coverage.md) in git, but NOT the source PDF
# copies (272MB across 288 facilities) or the regenerable _auto CSVs. The PDFs are
# copies of the gitignored data/permits/ originals; publish script recreates them.
permits/**/source.pdf
permits/**/equipment_list_auto.csv
docs/memory_archive/*.docx
